---
const facebookUrl = 'https://www.facebook.com/ThePutTogetherPooch/';

const photos = [
  { src: '/images/cavachon-yellow.jpg', alt: 'Freshly groomed white Cavachon in a yellow harness' },
  { src: '/images/rainbow-boston.jpg', alt: 'Boston terrier wearing a rainbow bandana' },
  { src: '/images/westie.jpg', alt: 'West Highland terrier on the grooming table' },
  { src: '/images/pom-lookup.jpg', alt: 'Cream Pomeranian looking up at the camera' },
  { src: '/images/yorkie-pom.jpg', alt: 'Yorkie mix in a red harness' },
  { src: '/images/shepherd-green.jpg', alt: 'Shepherd mix in a green holiday bandana' },
  { src: '/images/pom-brick.jpg', alt: 'Pomeranian by the brick wall' },
  { src: '/images/golden.jpg', alt: 'Golden retriever close-up' },
];
---

<section id="gallery" class="bg-base">
  <div class="max-w-6xl mx-auto px-5 py-20 md:py-24">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-8">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-muted mb-2">The Pups</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink">Our happy little clients</h2>
      </div>
      <a href={facebookUrl} class="inline-flex items-center gap-2 font-semibold text-blue hover:text-violet transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
        </svg>
        See more on Facebook →
      </a>
    </div>

    <!-- Clean uniform grid of real client pups -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      {photos.map((photo) => (
        <div class="group relative overflow-hidden rounded-2xl aspect-[4/5]">
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>
      ))}
    </div>

    <p class="text-muted text-sm mt-5 text-center">#PutTogetherPooch · #DenverDogGrooming · #CityParkWest</p>
  </div>
</section>
