---
---

<section id="hours" class="py-24 bg-base-soft text-ink">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="text-sm font-semibold uppercase tracking-widest mb-3 text-muted">Find Us</p>
      <h2 class="text-4xl md:text-5xl font-extrabold text-ink">Visit by Appointment</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-10 items-stretch">
      <!-- Appointment + location card -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-ink/5 flex flex-col justify-center">
        <div class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-brand mb-5">
          <span class="w-2 h-2 rounded-full bg-brand"></span>
          By appointment only
        </div>
        <p class="text-2xl font-extrabold text-ink leading-snug mb-2">Call to schedule your pup's visit.</p>
        <p class="text-muted mb-8">We groom one dog at a time, so every appointment is reserved just for you.</p>

        <div class="flex items-start gap-3 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-ink-soft mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <address class="not-italic text-sm leading-relaxed text-ink-soft">
            1438 E. 22nd Ave<br />Denver, CO 80205<br />
            <span class="text-muted">City Park West</span>
          </address>
        </div>

        <a href="tel:+13038614211" class="btn-rainbow inline-flex w-fit items-center gap-2 font-bold px-6 py-3 rounded-full text-sm">
          Call 303-861-4211
        </a>
      </div>

      <!-- Map (no gradient accents) -->
      <div class="rounded-2xl overflow-hidden min-h-80 shadow-sm border border-ink/5">
        <iframe
          title="Put Together Pooch location map"
          src="https://maps.google.com/maps?q=1438+E+22nd+Ave+Denver+CO+80205&output=embed&z=15"
          width="100%"
          height="100%"
          style="border:0; min-height: 360px;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>
