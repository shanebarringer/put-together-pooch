---
const hours = [
  { day: 'Tuesday', time: '10:00 AM – 6:00 PM' },
  { day: 'Wednesday', time: '10:00 AM – 6:00 PM' },
  { day: 'Thursday', time: '10:00 AM – 6:00 PM' },
  { day: 'Friday', time: '10:00 AM – 6:00 PM' },
  { day: 'Saturday', time: '10:00 AM – 6:00 PM' },
  { day: 'Sunday', time: '12:00 PM – 6:00 PM' },
  { day: 'Monday', time: 'Closed', closed: true },
];
---

<section id="hours" class="py-24 bg-forest text-white">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-16">
      <p class="text-gold-light text-sm font-semibold uppercase tracking-widest mb-3">Find Us</p>
      <h2 class="text-4xl md:text-5xl font-bold">Hours & Location</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <!-- Hours table -->
      <div>
        <div class="bg-white/10 rounded-2xl overflow-hidden">
          <div class="px-6 py-4 border-b border-white/10">
            <h3 class="font-semibold text-white">Business Hours</h3>
          </div>
          <div class="divide-y divide-white/10">
            {hours.map((row) => (
              <div class={`flex justify-between items-center px-6 py-3.5 ${row.closed ? 'opacity-50' : ''}`}>
                <span class="text-white/80 text-sm">{row.day}</span>
                <span class={`text-sm font-medium ${row.closed ? 'text-white/60' : 'text-white'}`}>{row.time}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="mt-6 space-y-3 text-white/80">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold-light mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <address class="not-italic text-sm leading-relaxed">
              1438 E. 22nd Ave<br />Denver, CO 80205<br />
              <span class="text-white/60">(City Park West neighborhood)</span>
            </address>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="rounded-2xl overflow-hidden h-80 md:h-full min-h-64 shadow-lg">
        <iframe
          title="Put Together Pooch location map"
          src="https://maps.google.com/maps?q=1438+E+22nd+Ave+Denver+CO+80205&output=embed&z=15"
          width="100%"
          height="100%"
          style="border:0; min-height: 320px;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>
