---
---

<section id="about" class="py-24 bg-cream">
  <div class="max-w-6xl mx-auto px-5">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <div class="rounded-3xl overflow-hidden aspect-[4/5]">
          <img
            src="https://images.unsplash.com/photo-1601979031925-424e53b6caaa?auto=format&fit=crop&w=800&q=80"
            alt="Happy dog after grooming at Put Together Pooch"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="absolute -bottom-5 -right-5 bg-forest text-white rounded-3xl px-6 py-4 shadow-xl">
          <p class="text-3xl font-bold leading-none">13+</p>
          <p class="text-sm font-medium mt-1 opacity-90">Years of happy pups</p>
        </div>
      </div>

      <div>
        <p class="text-forest text-sm font-bold uppercase tracking-widest mb-3">Our Story</p>
        <h2 class="text-4xl md:text-5xl font-bold text-bark leading-tight mb-6">
          We treat your dog like our own.
        </h2>
        <div class="space-y-4 text-muted text-lg leading-relaxed">
          <p>
            Put Together Pooch has been part of Denver's City Park West neighborhood since June 2012. We're not a factory. We know your dog's name, their quirks, what they hate (nail trims) and what they love (ear scratches).
          </p>
          <p>
            When you drop your pup off with us, you'll always know exactly who's doing the grooming. One dog at a time, one person at a time.
          </p>
        </div>

        <div class="mt-10 grid grid-cols-3 gap-4">
          {[
            { emoji: '🛁', label: 'Self-Service Wash' },
            { emoji: '✂️', label: 'Full Grooming' },
            { emoji: '❤️', label: 'Dog-Obsessed Staff' },
          ].map(item => (
            <div class="bg-cream-dark rounded-2xl p-4 text-center">
              <div class="text-2xl mb-2">{item.emoji}</div>
              <p class="text-xs font-semibold text-bark-soft leading-tight">{item.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
