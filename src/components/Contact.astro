---
const facebookUrl = 'https://www.facebook.com/ThePutTogetherPooch/';
---

<section id="contact" class="py-24 bg-base">
  <div class="max-w-3xl mx-auto px-5 text-center">
    <p class="text-sm font-semibold uppercase tracking-widest mb-3 text-muted">Get In Touch</p>
    <h2 class="text-4xl md:text-5xl font-extrabold text-ink mb-4">
      Ready to <span class="text-brand">book?</span>
    </h2>
    <p class="text-muted text-lg mb-12 max-w-md mx-auto">
      We groom by appointment only. Give us a call and we'll set up a consultation for your pup.
    </p>

    <!-- Single phone CTA card -->
    <a
      href="tel:+13038614211"
      class="group block max-w-md mx-auto rounded-3xl p-[3px] mb-8"
      style="background: var(--gradient-rainbow);"
    >
      <div class="bg-base rounded-[21px] p-8 flex flex-col items-center gap-3 transition-colors group-hover:bg-base-soft">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white" style="background: var(--gradient-rainbow);">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
        </div>
        <p class="text-xs text-muted uppercase tracking-wider">Call for a consultation</p>
        <p class="text-3xl font-extrabold text-ink">303-861-4211</p>
        <p class="text-sm text-muted">By appointment only</p>
      </div>
    </a>

    <!-- Facebook follow -->
    <div class="mb-12">
      <a href={facebookUrl} class="inline-flex items-center gap-2 font-semibold text-blue hover:text-violet transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
        </svg>
        Follow us on Facebook
      </a>
    </div>

    <div class="inline-flex items-center gap-2 text-muted text-sm bg-base-soft rounded-full px-5 py-2.5">
      <span class="w-2 h-2 rounded-full" style="background: var(--gradient-rainbow);"></span>
      <span>Trusted by Denver dogs since 2012</span>
    </div>
  </div>
</section>
