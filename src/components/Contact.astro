<section id="contact" class="py-24 bg-cream-dark">
  <div class="max-w-4xl mx-auto px-5 text-center">
    <p class="text-forest text-sm font-semibold uppercase tracking-widest mb-3">Get In Touch</p>
    <h2 class="text-4xl md:text-5xl font-bold text-bark mb-4">Ready to book?</h2>
    <p class="text-muted text-lg mb-12 max-w-md mx-auto">
      Give us a call or shoot us an email. We'd love to meet your pup.
    </p>

    <div class="grid sm:grid-cols-2 gap-6 max-w-lg mx-auto mb-12">
      <a
        href="tel:+13038614211"
        class="group flex flex-col items-center gap-3 bg-cream rounded-2xl p-8 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5"
      >
        <div class="w-14 h-14 bg-forest/10 text-forest rounded-xl flex items-center justify-center group-hover:bg-forest group-hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs text-muted uppercase tracking-wider mb-1">Call</p>
          <p class="font-semibold text-bark">303-861-4211</p>
        </div>
      </a>

      <a
        href="mailto:theputtogetherpooch@qwestoffice.net"
        class="group flex flex-col items-center gap-3 bg-cream rounded-2xl p-8 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5"
      >
        <div class="w-14 h-14 bg-forest/10 text-forest rounded-xl flex items-center justify-center group-hover:bg-forest group-hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-muted uppercase tracking-wider mb-1">Email</p>
          <p class="font-semibold text-bark text-sm">theputtogetherpooch<br />@qwestoffice.net</p>
        </div>
      </a>
    </div>

    <div class="inline-flex items-center gap-2 text-muted text-sm bg-cream rounded-full px-5 py-2.5">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="currentColor">
        <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
      </svg>
      <span>Trusted by Denver dogs since 2012</span>
    </div>
  </div>
</section>
