---
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
  style="padding-top: 64px;"
>
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=1920&q=80"
      alt="Golden retriever getting a bath at Put Together Pooch"
      class="w-full h-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-bark/85 via-forest/70 to-forest/50"></div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-5 text-center text-white">
    <!-- Paw print accent -->
    <div class="flex justify-center gap-1 mb-6 text-2xl opacity-80">🐾</div>
    <p class="text-gold-light text-sm font-semibold uppercase tracking-widest mb-4">Denver's Favorite Dog Groomer</p>
    <h1 class="text-5xl md:text-7xl font-bold leading-tight mb-6">
      Drop off the chaos.<br />Pick up the fluff.
    </h1>
    <p class="text-white/85 text-lg md:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
      Professional grooming and self-service dog wash in City Park West. We've been making Denver pups look their best since 2012.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="tel:+13038614211"
        class="inline-flex items-center justify-center gap-2 bg-forest hover:bg-forest-light text-white font-bold px-8 py-4 rounded-full text-base transition-all hover:scale-105 shadow-lg"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        Book Now: 303-861-4211
      </a>
      <a
        href="#services"
        class="inline-flex items-center justify-center gap-2 bg-white/15 hover:bg-white/25 text-white font-semibold px-8 py-4 rounded-full text-base border border-white/40 transition-all backdrop-blur-sm"
      >
        What We Do
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
