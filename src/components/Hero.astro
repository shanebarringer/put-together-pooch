---
---

<section class="relative h-screen flex items-end overflow-hidden">
  <!-- Full-bleed image, almost no overlay so photo dominates -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=1920&q=80"
      alt="Golden retriever getting a bath at Put Together Pooch"
      class="w-full h-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/40 to-transparent"></div>
  </div>

  <!-- Content anchored to bottom -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-5 pb-16 md:pb-24">
    <div class="max-w-2xl">
      <p class="text-gold text-sm font-semibold uppercase tracking-widest mb-4">City Park West, Denver</p>
      <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight mb-6">
        Professional dog grooming.<br />Personal attention.
      </h1>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="tel:+13038614211"
          class="inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-forest font-bold px-8 py-4 rounded-full text-base transition-all hover:scale-105 shadow-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          Call 303-861-4211
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-full text-base border border-white/30 transition-all backdrop-blur-sm"
        >
          Our Services
        </a>
      </div>
    </div>
  </div>
</section>
