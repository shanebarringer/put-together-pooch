---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11" />
    </svg>`,
    title: 'Self-Service Dog Wash',
    description: "Got a muddy pup? Use our professional-grade tubs, shampoos, and dryers. All the tools, none of the mess at home. Perfect for regular maintenance washes between grooming appointments.",
    features: ['Professional tubs & shampoo', 'Dryers & towels provided', 'No appointment needed', 'Bring your own products or use ours'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
    </svg>`,
    title: 'Professional Grooming',
    description: "Full-service grooming tailored to your dog's breed, coat type, and personality. We take our time. Every dog is treated as an individual, not a number.",
    features: ['Breed-appropriate cuts', 'Bath, dry & brush-out', 'Nail trim & ear cleaning', 'Personal one-on-one attention'],
  },
];
---

<section id="services" class="py-24 bg-cream-dark">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-16">
      <p class="text-forest text-sm font-semibold uppercase tracking-widest mb-3">What We Do</p>
      <h2 class="text-4xl md:text-5xl font-bold text-bark">Services</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {services.map((service) => (
        <div class="bg-cream rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-16 h-16 bg-forest/10 text-forest rounded-2xl flex items-center justify-center mb-6">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="text-2xl font-bold text-bark mb-3">{service.title}</h3>
          <p class="text-muted leading-relaxed mb-6">{service.description}</p>
          <ul class="space-y-2.5">
            {service.features.map((feat) => (
              <li class="flex items-start gap-3 text-sm text-bark-soft">
                <svg class="w-4 h-4 text-sage mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {feat}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <p class="text-muted mb-4">Questions about pricing or a specific breed?</p>
      <a
        href="tel:+13038614211"
        class="inline-flex items-center gap-2 bg-forest hover:bg-forest-light text-white font-semibold px-8 py-4 rounded-full transition-all hover:scale-105"
      >
        Call Us: 303-861-4211
      </a>
    </div>
  </div>
</section>
