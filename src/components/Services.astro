---
const services = [
  {
    emoji: '🛁',
    title: 'Self-Service Dog Wash',
    tagline: 'All the tools, none of the mess.',
    description: "Got a muddy pup? Use our professional tubs, shampoos, and dryers. You do the scrubbing, we handle the cleanup.",
    features: ['Pro-grade tubs and shampoo', 'Dryers and towels included', 'Walk-ins welcome', 'Bring your own or use ours'],
  },
  {
    emoji: '✂️',
    title: 'Professional Grooming',
    tagline: 'Your dog, looking their best.',
    description: "Full-service grooming built around your dog's personality and coat. We take our time. Every dog is treated as an individual, not a number.",
    features: ['Breed-appropriate cuts', 'Bath, dry and brush-out', 'Nail trim and ear cleaning', 'One groomer, one dog, full attention'],
  },
];
---

<section id="services" class="py-24 bg-cream-dark">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-16">
      <p class="text-forest text-sm font-bold uppercase tracking-widest mb-3">What We Do</p>
      <h2 class="text-4xl md:text-5xl font-bold text-bark">Services</h2>
      <p class="text-muted mt-4 max-w-sm mx-auto">Two ways to get your pup looking great.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {services.map((service) => (
        <div class="bg-cream rounded-3xl p-8 md:p-10 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1">
          <div class="text-5xl mb-6">{service.emoji}</div>
          <p class="text-forest text-xs font-bold uppercase tracking-widest mb-1">{service.tagline}</p>
          <h3 class="text-2xl font-bold text-bark mb-3">{service.title}</h3>
          <p class="text-muted leading-relaxed mb-6">{service.description}</p>
          <ul class="space-y-2.5">
            {service.features.map((feat) => (
              <li class="flex items-start gap-3 text-sm text-bark-soft">
                <span class="text-forest mt-0.5">🐾</span>
                {feat}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <p class="text-muted mb-4">Questions? Just give us a ring.</p>
      <a
        href="tel:+13038614211"
        class="inline-flex items-center gap-2 bg-forest hover:bg-forest-light text-white font-bold px-8 py-4 rounded-full transition-all hover:scale-105 shadow-md"
      >
        Call Us: 303-861-4211
      </a>
    </div>
  </div>
</section>
