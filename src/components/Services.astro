---
const services = [
  {
    name: 'Self-Service Dog Wash',
    description: "Our tubs, our shampoo, our dryers — your dog, your way. No appointment needed.",
    detail: 'Walk-ins welcome',
  },
  {
    name: 'Full Grooming',
    description: "Bath, blow-dry, breed-appropriate cut, nail trim, ear cleaning. One groomer, start to finish.",
    detail: 'Call for pricing',
  },
  {
    name: 'Nail Trim',
    description: "Quick nail trim, no full groom needed. In and out.",
    detail: 'Walk-ins welcome',
  },
];
---

<section id="services" class="py-24 bg-cream">
  <div class="max-w-6xl mx-auto px-5">

    <div class="flex items-end justify-between mb-4">
      <p class="text-bark text-xs font-bold uppercase tracking-[0.2em] text-muted">Services</p>
      <p class="text-bark text-xs font-bold uppercase tracking-[0.2em] text-muted hidden sm:block">Availability</p>
    </div>

    <div class="border-t border-bark/10">
      {services.map((service) => (
        <div class="group border-b border-bark/10 py-8 grid sm:grid-cols-[1fr_auto] gap-4 sm:gap-12 items-start hover:bg-cream-dark -mx-5 px-5 transition-colors">
          <div>
            <h3 class="text-2xl font-bold text-bark mb-2 group-hover:text-forest transition-colors">{service.name}</h3>
            <p class="text-muted leading-relaxed max-w-xl">{service.description}</p>
          </div>
          <div class="shrink-0">
            <span class="inline-block bg-forest/8 text-bark-soft text-sm font-medium px-4 py-2 rounded-lg">{service.detail}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-8 border-t border-bark/10">
      <p class="text-muted">Every appointment is personal. We don't rush.</p>
      <a
        href="tel:+13038614211"
        class="inline-flex items-center gap-2 bg-forest hover:bg-forest-light text-white font-semibold px-7 py-3.5 rounded-lg text-sm transition-colors"
      >
        Call to book
      </a>
    </div>
  </div>
</section>
